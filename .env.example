# Z.ai credentials
# Your coding plan API key (the one you use in Claude Code / Cline / opencode).
# Format: xxxxxxxxxxxx.yyyyyyyyyyyyyyyy
ZAI_API_KEY=

# Optional friendly label for this account (shown in the TUI under the email and
# in Telegram messages). Useful when you monitor several coding accounts.
# Leave empty to hide it. (Can also be set in config.toml -> [zai] name.)
ZAI_ACCOUNT_NAME=

# Telegram (leave empty to disable alerts)
TG_BOT_TOKEN=
TG_CHAT_ID=

# Polling interval (seconds) for the background alert daemon
POLL_INTERVAL=300
