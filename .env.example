# Z.ai credentials
# Option A: your coding plan API key (the one you use in Claude Code / opencode).
#           Starts with a long opaque string. The probe will tell us if the
#           /biz/subscription/list endpoint accepts it.
ZAI_API_KEY=

# Option B (fallback, more reliable): bearer JWT from the browser session.
#   How to get it:
#     1. Open https://z.ai/manage-apikey/coding-plan/personal/my-plan (log in)
#     2. DevTools -> Application -> Local Storage -> https://z.ai
#     3. Find key "auth-user-storage", copy the value
#     4. Inside that JSON, locate "accessToken" (or similar) -> that's the JWT.
#     5. Paste it here. It expires; refresh when the probe returns code 1001/401.
ZAI_JWT=

# Telegram (leave empty to disable alerts)
TG_BOT_TOKEN=
TG_CHAT_ID=

# Polling interval (seconds) for the background alert daemon
POLL_INTERVAL=300
